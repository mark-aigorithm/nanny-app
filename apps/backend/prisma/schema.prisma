// ──────────────────────────────────────────────────────────────
// NannyApp — Prisma Schema
// ──────────────────────────────────────────────────────────────
// Conventions:
//   • Every model must have created_at, updated_at, deleted_at (soft delete)
//   • DB columns use snake_case via @map; Prisma fields use camelCase
//   • Table names are plural snake_case via @@map
//   • Enums are PascalCase in Prisma, snake_case in DB via @@map
//   • PostGIS geography columns are Unsupported — use $queryRaw
//   • Primary keys are sequential integers: Int @id @default(autoincrement()).
//     Foreign-key columns are Int / Int?. Natural/business identifiers
//     (firebase_uid, email, codes, tokens, paymob ids) remain String.
// ──────────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  // The postgis/postgis Docker image pre-installs these four extensions
  // as part of its init scripts. Declare all of them so Prisma's drift
  // detection matches the actual database state on fresh dev environments.
  extensions = [fuzzystrmatch, postgis, postgis_tiger_geocoder, postgis_topology]
}

// ──────────────────────────────────────────────────────────────
// Auth & Identity
// ──────────────────────────────────────────────────────────────

enum Role {
  MOTHER
  NANNY
  ADMIN
  SUPERUSER

  @@map("role")
}

enum BookingStatus {
  PENDING
  APPROVED
  PENDING_CONFIRMATION
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REFUNDED

  @@map("booking_status")
}

/// Nanny's optional, informational response to a booking request. Purely
/// advisory — the admin's approval is authoritative and overrides this. A
/// nanny may ACCEPT or DECLINE; the booking's lifecycle status is unaffected.
enum NannyBookingDecision {
  PENDING
  ACCEPTED
  DECLINED

  @@map("nanny_booking_decision")
}

enum BookingType {
  STANDARD

  @@map("booking_type")
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED

  @@map("payment_status")
}

enum PaymentMethod {
  CARD
  APPLE_PAY
  GOOGLE_PAY
  WALLET

  @@map("payment_method")
}

enum NannyApprovalStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED

  @@map("nanny_approval_status")
}

/// Identity-verification state shared by nannies AND mothers (lives on `users`).
/// PENDING_ID = must (re)upload; PENDING_REVIEW = awaiting admin; APPROVED / REJECTED.
enum IdVerificationStatus {
  PENDING_ID
  PENDING_REVIEW
  APPROVED
  REJECTED

  @@map("id_verification_status")
}

/// Government ID kind. PASSPORT needs only the front image; NATIONAL_ID needs both.
enum IdDocumentType {
  PASSPORT
  NATIONAL_ID

  @@map("id_document_type")
}

enum AvailabilityType {
  FULL_TIME
  PART_TIME
  OCCASIONAL

  @@map("availability_type")
}

enum CareLogType {
  MEAL
  NAP
  DIAPER
  ACTIVITY
  CUSTOM

  @@map("care_log_type")
}

/// Central identity row — one per Firebase Auth user.
/// Role-specific data (children, certifications, bio, location) lives on
/// future MotherProfile / NannyProfile models, not here.
/// Note: the spec's single `isVerified` flag is intentionally split into
/// `isEmailVerified` / `isPhoneVerified` — email can be re-verified on
/// change independently of phone (AUTH-10).
model User {
  id                   Int       @id @default(autoincrement())
  firebaseUid          String    @unique @map("firebase_uid")
  email                String    @unique
  phone                String?   @unique // E.164
  firstName            String    @map("first_name")
  lastName             String    @map("last_name")
  dateOfBirth          DateTime? @map("date_of_birth") @db.Date
  avatarUrl            String?   @map("avatar_url")
  // Nullable: social sign-in creates a User before the role is chosen;
  // `/auth/set-role` (AUTH-08) fills it in.
  role                 Role?
  isEmailVerified      Boolean   @default(false) @map("is_email_verified")
  isPhoneVerified      Boolean   @default(false) @map("is_phone_verified")
  isActive             Boolean   @default(true) @map("is_active")
  lastLoginAt          DateTime? @map("last_login_at")
  emailVerifiedAt      DateTime? @map("email_verified_at")
  phoneVerifiedAt      DateTime? @map("phone_verified_at")
  termsAcceptedAt      DateTime? @map("terms_accepted_at")
  termsAcceptedVersion String?   @map("terms_accepted_version")
  /// Street address + home coordinates captured by the registration map
  /// picker. Single source of truth for location — proximity search and
  /// distance sorting (nanny listing + booking broadcast) read lat/lng here.
  address              String?
  latitude             Decimal?  @db.Decimal(10, 7)
  longitude            Decimal?  @db.Decimal(10, 7)
  /// Identity documents + KYC state, for BOTH nannies and mothers. Nannies must
  /// be APPROVED to appear in search / use the app; mothers must have uploaded
  /// an ID (not PENDING_ID/REJECTED) before booking. Null for admins/role-less.
  idVerificationStatus IdVerificationStatus? @map("id_verification_status")
  idDocumentType       IdDocumentType?       @map("id_document_type")
  idDocumentFrontUrl   String?               @map("id_document_front_url")
  idDocumentBackUrl    String?               @map("id_document_back_url")
  idReviewedAt         DateTime?             @map("id_reviewed_at")
  idRejectionReason    String?               @map("id_rejection_reason")
  // Soft-delete grace window (AUTH-14): 30-day window before PII is purged.
  deletionRequestedAt  DateTime? @map("deletion_requested_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")

  nannyProfile             NannyProfile?
  bookingsAsMother         Booking[]                 @relation("BookingMother")
  cancelledBookings        Booking[]                 @relation("BookingCancelledBy")
  approvedBookings         Booking[]                 @relation("BookingAdminApprover")
  actionedBookings         Booking[]                 @relation("BookingAdminActor")
  payments                 Payment[]                 @relation("PaymentMother")
  reviewsGiven             Review[]                  @relation("ReviewMother")
  communityPosts           CommunityPost[]
  postLikes                PostLike[]
  comments                 Comment[]
  commentLikes             CommentLike[]
  eventRsvps               EventRsvp[]
  conversationParticipants ConversationParticipant[]
  messagesSent             Message[]
  notifications            Notification[]
  deviceTokens             DeviceToken[]
  initiatedConversations   Conversation[]            @relation("ConversationInitiator")
  promoRedemptions         PromoCodeRedemption[]
  cameras                  Camera[]                  @relation("NannyCameras")
  rewardWallet             RewardWallet?
  rewardLedger             RewardLedgerEntry[]       @relation("RewardLedgerUser")
  rewardGrantsMade         RewardLedgerEntry[]       @relation("RewardGrantAdmin")

  @@index([role])
  @@index([deletedAt])
  @@index([idVerificationStatus])
  @@map("users")
}

/// Nanny-specific extended profile. Created automatically when role = NANNY
/// on /auth/register. One-to-one with User.
model NannyProfile {
  id                 Int                 @id @default(autoincrement())
  userId             Int                 @unique @map("user_id")
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio                String?             @db.Text
  yearsOfExperience  Int?                @map("years_of_experience")
  certifications     String[]
  ageRanges          String[]            @map("age_ranges")
  specialties        String[]            @default([])
  /// Weekly schedule JSON: { "0": { available, startTime, endTime }, … "6": … }
  schedule           Json?
  isProfileComplete  Boolean             @default(false) @map("is_profile_complete")
  /// Admin vetting gate: new nannies start PENDING_REVIEW and cannot appear
  /// in search or use the app until an admin approves them (KYC).
  approvalStatus     NannyApprovalStatus @default(PENDING_REVIEW) @map("approval_status")
  reviewedAt         DateTime?           @map("reviewed_at")
  rejectionReason    String?             @map("rejection_reason")
  /// Identity documents captured at registration for admin KYC review.
  idDocumentFrontUrl String?             @map("id_document_front_url")
  idDocumentBackUrl  String?             @map("id_document_back_url")
  /// Availability type for filtering: FULL_TIME, PART_TIME, OCCASIONAL
  availabilityType   AvailabilityType    @default(OCCASIONAL) @map("availability_type")
  /// Denormalised rating cache — recomputed on every new review.
  rating             Decimal             @default(0) @db.Decimal(3, 2)
  reviewCount        Int                 @default(0) @map("review_count")
  bookings           Booking[]
  reviews            Review[]
  careLogs           CareLog[]
  nannySkills        NannySkill[]
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  deletedAt          DateTime?           @map("deleted_at")

  @@index([availabilityType])
  @@index([rating])
  @@index([approvalStatus])
  @@map("nanny_profiles")
}

/// Admin-curated catalog of nanny specialties (e.g. "French speaker",
/// "Works with disabilities"). Controlled replacement for the free-text
/// NannyProfile.specialties array. Linked to nannies via NannySkill.
model Skill {
  id          Int           @id @default(autoincrement())
  name        String        @unique
  description String?       @db.Text
  isActive    Boolean       @default(true) @map("is_active")
  /// Optional booking add-on fee. When a mother selects this skill as a paid
  /// add-on, its fee is applied on top of the base hourly rate. null feeType
  /// (the default) means the skill carries no fee. FLAT = EGP/hour surcharge;
  /// PERCENTAGE = percent of the base rate added per hour.
  feeType     DiscountType? @map("fee_type")
  feeValue    Decimal       @default(0) @map("fee_value") @db.Decimal(10, 2)
  nannySkills NannySkill[]
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  @@index([deletedAt])
  @@map("skills")
}

/// Many-to-many join between a nanny and a skill. Assigned by admins.
model NannySkill {
  id             Int          @id @default(autoincrement())
  nannyProfileId Int          @map("nanny_profile_id")
  nannyProfile   NannyProfile @relation(fields: [nannyProfileId], references: [id], onDelete: Cascade)
  skillId        Int          @map("skill_id")
  skill          Skill        @relation(fields: [skillId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  @@unique([nannyProfileId, skillId])
  @@index([nannyProfileId])
  @@index([skillId])
  @@map("nanny_skills")
}

// ──────────────────────────────────────────────────────────────
// App Config
// ──────────────────────────────────────────────────────────────

/// Singleton key-value store for runtime-configurable settings (e.g. service_fee_percent).
/// Never hard-code config values that operations may need to tune without a deploy.
model AppSettings {
  id        Int       @id @default(autoincrement())
  key       String    @unique
  value     String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("app_settings")
}

enum DiscountType {
  FLAT
  PERCENTAGE

  @@map("discount_type")
}

/// Admin-configured duration pricing tiers. When a booking's durationHours is
/// at least `minHours`, the highest matching tier's `multiplier` is applied to
/// the subtotal (e.g. a 3-hour booking at multiplier 0.90 gets a 10% discount).
/// With no matching tier the multiplier defaults to 1.0 (no adjustment).
model DurationMultiplierRule {
  id         Int       @id @default(autoincrement())
  /// Inclusive lower bound in hours for this tier to apply.
  minHours   Int       @map("min_hours")
  /// Factor applied to the subtotal (0.90 = 10% discount, 1.10 = 10% surcharge).
  multiplier Decimal   @db.Decimal(5, 4)
  label      String?
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@index([isActive])
  @@index([deletedAt])
  @@map("duration_multiplier_rules")
}

model PromoCode {
  id              Int          @id @default(autoincrement())
  code            String       @unique
  discountType    DiscountType @map("discount_type")
  /// Flat amount in EGP, or percentage when discount_type = PERCENTAGE.
  value           Decimal      @db.Decimal(10, 2)
  /// Total redemptions allowed across all users; null = unlimited.
  maxUsage        Int?         @map("max_usage")
  /// Redemptions allowed per user; null = unlimited.
  maxUsagePerUser Int?         @map("max_usage_per_user")
  usageCount      Int          @default(0) @map("usage_count")
  isActive        Boolean      @default(true) @map("is_active")
  expiresAt       DateTime?    @map("expires_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")

  redemptions PromoCodeRedemption[]
  bookings    Booking[]

  @@index([isActive])
  @@index([deletedAt])
  @@map("promo_codes")
}

model PromoCodeRedemption {
  id          Int       @id @default(autoincrement())
  promoCodeId Int       @map("promo_code_id")
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id])
  userId      Int       @map("user_id")
  user        User      @relation(fields: [userId], references: [id])
  /// Soft reference to the booking the code was applied to (no FK constraint).
  bookingId   Int?      @map("booking_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([promoCodeId, userId])
  @@index([userId])
  @@map("promo_code_redemptions")
}

// ──────────────────────────────────────────────────────────────
// Care Points (rewards)
// ──────────────────────────────────────────────────────────────

/// How a Care Points ledger entry moved a balance.
enum RewardEntryType {
  EARN
  REDEEM
  REFUND
  ADMIN_GRANT
  ADMIN_REVOKE

  @@map("reward_entry_type")
}

/// Singleton earn/redeem rates for the Care Points program. A single active
/// row is upserted by the admin config screen.
model RewardConfig {
  id                      Int       @id @default(autoincrement())
  enabled                 Boolean   @default(true)
  /// Points granted per completed booked hour.
  pointsPerBookedHour     Int       @default(10) @map("points_per_booked_hour")
  /// Points required to redeem one free care hour.
  redemptionPointsPerHour Int       @default(100) @map("redemption_points_per_hour")
  /// Minimum points a user must spend in a single redemption.
  minRedemptionPoints     Int       @default(100) @map("min_redemption_points")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  deletedAt               DateTime? @map("deleted_at")

  @@map("reward_config")
}

/// A user's Care Points balance and redeemed-but-unapplied credit. 1:1 with User.
model RewardWallet {
  id               Int       @id @default(autoincrement())
  userId           Int       @unique @map("user_id")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pointsBalance    Int       @default(0) @map("points_balance")
  lifetimeEarned   Int       @default(0) @map("lifetime_earned")
  lifetimeRedeemed Int       @default(0) @map("lifetime_redeemed")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  entries RewardLedgerEntry[]

  @@map("reward_wallets")
}

/// Append-only history of every Care Points movement (the "wallet history").
model RewardLedgerEntry {
  id           Int             @id @default(autoincrement())
  walletId     Int             @map("wallet_id")
  wallet       RewardWallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)
  userId       Int             @map("user_id")
  user         User            @relation("RewardLedgerUser", fields: [userId], references: [id])
  type         RewardEntryType
  /// Signed delta: positive = credited, negative = debited.
  points       Int
  /// Running balance immediately after this entry was applied.
  balanceAfter Int             @map("balance_after")
  reason       String?
  /// Set on EARN entries (the booking that generated the points).
  bookingId    Int?            @map("booking_id")
  /// Set on ADMIN_GRANT / ADMIN_REVOKE (the acting admin).
  adminId      Int?            @map("admin_id")
  admin        User?           @relation("RewardGrantAdmin", fields: [adminId], references: [id])
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  deletedAt    DateTime?       @map("deleted_at")

  @@index([userId, createdAt])
  @@index([bookingId])
  @@map("reward_ledger_entries")
}

// ──────────────────────────────────────────────────────────────
// Booking & Payments
// ──────────────────────────────────────────────────────────────

model Booking {
  id                       Int                  @id @default(autoincrement())
  motherId                 Int                  @map("mother_id")
  mother                   User                 @relation("BookingMother", fields: [motherId], references: [id])
  /// Null while a broadcast request is unclaimed, until a nanny accepts.
  nannyProfileId           Int?                 @map("nanny_profile_id")
  nannyProfile             NannyProfile?        @relation(fields: [nannyProfileId], references: [id])
  promoCodeId              Int?                 @map("promo_code_id")
  promoCode                PromoCode?           @relation(fields: [promoCodeId], references: [id])
  status                   BookingStatus        @default(PENDING)
  /// Nanny's optional accept/decline of the request. Informational only —
  /// see NannyBookingDecision. Admin approval is authoritative regardless.
  nannyDecision            NannyBookingDecision @default(PENDING) @map("nanny_decision")
  nannyDecidedAt           DateTime?            @map("nanny_decided_at")
  /// Admin who approved the booking (PENDING → APPROVED), plus timestamp.
  adminApprovedById        Int?                 @map("admin_approved_by_id")
  adminApprovedBy          User?                @relation("BookingAdminApprover", fields: [adminApprovedById], references: [id])
  adminApprovedAt          DateTime?            @map("admin_approved_at")
  /// Audit trail for any admin status override (PATCH /admin/bookings/:id/status).
  adminActionById          Int?                 @map("admin_action_by_id")
  adminActionBy            User?                @relation("BookingAdminActor", fields: [adminActionById], references: [id])
  adminActionAt            DateTime?            @map("admin_action_at")
  type                     BookingType          @default(STANDARD)
  date                     DateTime             @db.Date
  startTime                DateTime             @map("start_time")
  endTime                  DateTime             @map("end_time")
  durationHours            Decimal              @map("duration_hours") @db.Decimal(5, 2)
  baseRate                 Decimal              @map("base_rate") @db.Decimal(10, 2)
  /// Base rate plus any selected per-skill add-on fees (per hour).
  effectiveHourlyRate      Decimal              @default(0) @map("effective_hourly_rate") @db.Decimal(10, 2)
  subtotal                 Decimal              @db.Decimal(10, 2)
  /// Duration tier factor applied to the subtotal (1 = none). See DurationMultiplierRule.
  durationMultiplier       Decimal              @default(1) @map("duration_multiplier") @db.Decimal(5, 4)
  discountAmount           Decimal              @default(0) @map("discount_amount") @db.Decimal(10, 2)
  /// Care Points redeemed against this booking before payment: free hours
  /// applied, the points they cost, and their monetary value (folded into
  /// discountAmount). Refunded if the payment is not completed. See RewardWallet.
  rewardCreditHoursApplied Decimal              @default(0) @map("reward_credit_hours_applied") @db.Decimal(6, 2)
  rewardCreditPoints       Int                  @default(0) @map("reward_credit_points")
  rewardCreditAmount       Decimal              @default(0) @map("reward_credit_amount") @db.Decimal(10, 2)
  /// Legacy platform service-fee snapshot. Superseded by the nanny/platform
  /// revenue split (nannyAmount / platformAmount); retained for old bookings.
  serviceFeePercent        Decimal              @map("service_fee_percent") @db.Decimal(5, 2)
  serviceFeeAmount         Decimal              @map("service_fee_amount") @db.Decimal(10, 2)
  totalAmount              Decimal              @map("total_amount") @db.Decimal(10, 2)
  /// Revenue split snapshot: what the nanny earns and what the platform keeps
  /// of totalAmount. Nannies only ever see nannyAmount.
  nannyAmount              Decimal              @default(0) @map("nanny_amount") @db.Decimal(10, 2)
  platformAmount           Decimal              @default(0) @map("platform_amount") @db.Decimal(10, 2)
  /// Snapshot of the selected skill add-ons for the price breakdown display.
  selectedSkillFees        Json?                @map("selected_skill_fees")
  specialInstructions      String?              @map("special_instructions") @db.Text
  /// Location snapshot copied from the mother's profile at creation time —
  /// used to radius-filter the nanny broadcast (see notifyBookingBroadcast).
  /// Null (mother has no saved location) → the request broadcasts to everyone.
  latitude                 Decimal?             @db.Decimal(10, 7)
  longitude                Decimal?             @db.Decimal(10, 7)
  cancellationReason       String?              @map("cancellation_reason")
  cancelledById            Int?                 @map("cancelled_by_id")
  cancelledBy              User?                @relation("BookingCancelledBy", fields: [cancelledById], references: [id])
  cancelledAt              DateTime?            @map("cancelled_at")
  nannyCheckedInAt         DateTime?            @map("nanny_checked_in_at")
  nannyCheckedOutAt        DateTime?            @map("nanny_checked_out_at")
  /// Parent-generated hand-off PIN gating nanny check-in. The parent reveals a
  /// 4-digit code within the check-in window; the nanny must enter it to start.
  /// Stored hashed (sha-256) and cleared on successful check-in. See booking.service.
  startPinHash             String?              @map("start_pin_hash")
  startPinGeneratedAt      DateTime?            @map("start_pin_generated_at")
  startPinExpiresAt        DateTime?            @map("start_pin_expires_at")
  startPinAttempts         Int                  @default(0) @map("start_pin_attempts")
  replacementForBookingId  Int?                 @map("replacement_for_booking_id")
  replacementForBooking    Booking?             @relation("BookingReplacement", fields: [replacementForBookingId], references: [id])
  replacementBookings      Booking[]            @relation("BookingReplacement")
  payment                  Payment?
  createdAt                DateTime             @default(now()) @map("created_at")
  updatedAt                DateTime             @updatedAt @map("updated_at")
  deletedAt                DateTime?            @map("deleted_at")

  review   Review?
  careLogs CareLog[]

  @@index([motherId])
  @@index([nannyProfileId])
  @@index([status])
  @@index([nannyDecision])
  @@index([date])
  @@index([promoCodeId])
  @@map("bookings")
}

model Payment {
  id                      Int           @id @default(autoincrement())
  bookingId               Int           @unique @map("booking_id")
  booking                 Booking       @relation(fields: [bookingId], references: [id])
  motherId                Int           @map("mother_id")
  mother                  User          @relation("PaymentMother", fields: [motherId], references: [id])
  amount                  Decimal       @db.Decimal(10, 2)
  currency                String        @default("EGP")
  method                  PaymentMethod
  status                  PaymentStatus @default(PENDING)
  paymobOrderId           String?       @map("paymob_order_id")
  paymobTransactionId     String?       @map("paymob_transaction_id")
  /// Paymob unified intention id (`id` from create-intention response).
  paymobIntentionId       String?       @map("paymob_intention_id")
  /// One-time client secret for Pixel / unified checkout and for server-side intention polling.
  paymobClientSecret      String?       @map("paymob_client_secret") @db.Text
  /// Incremented each time a new Paymob intention is created (retry-safe merchant order ids).
  paymobIntentionAttempt  Int           @default(0) @map("paymob_intention_attempt")
  /// T0 for staggered reconciliation (usually intention creation time).
  paymobReconcileAnchorAt DateTime?     @map("paymob_reconcile_anchor_at")
  /// Number of reconciliation polls already executed (0..PAYMOB_RECONCILE_OFFSETS_MS.length).
  paymobReconcileAttempt  Int           @default(0) @map("paymob_reconcile_attempt")
  paymobNextReconcileAt   DateTime?     @map("paymob_next_reconcile_at")
  failureReason           String?       @map("failure_reason")
  refundedAmount          Decimal       @default(0) @map("refunded_amount") @db.Decimal(10, 2)
  refundedAt              DateTime?     @map("refunded_at")
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime      @updatedAt @map("updated_at")
  deletedAt               DateTime?     @map("deleted_at")

  @@index([paymobOrderId])
  @@index([paymobNextReconcileAt])
  @@map("payments")
}

// ──────────────────────────────────────────────────────────────
// Reviews
// ──────────────────────────────────────────────────────────────

model Review {
  id             Int          @id @default(autoincrement())
  bookingId      Int          @unique @map("booking_id")
  booking        Booking      @relation(fields: [bookingId], references: [id])
  nannyProfileId Int          @map("nanny_profile_id")
  nannyProfile   NannyProfile @relation(fields: [nannyProfileId], references: [id])
  motherId       Int          @map("mother_id")
  mother         User         @relation("ReviewMother", fields: [motherId], references: [id])
  rating         Int
  comment        String?      @db.Text
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  @@index([nannyProfileId])
  @@index([motherId])
  @@map("reviews")
}

// ──────────────────────────────────────────────────────────────
// Care Logs
// ──────────────────────────────────────────────────────────────

/// One entry per logged activity during an in-progress booking.
/// `customLabel` is required only for type = CUSTOM. Evidence is a list of
/// remote image URLs (clients upload the file to Firebase Storage first and
/// then submit the resulting URL).
model CareLog {
  id             Int          @id @default(autoincrement())
  bookingId      Int          @map("booking_id")
  booking        Booking      @relation(fields: [bookingId], references: [id])
  nannyProfileId Int          @map("nanny_profile_id")
  nannyProfile   NannyProfile @relation(fields: [nannyProfileId], references: [id])
  type           CareLogType
  customLabel    String?      @map("custom_label")
  notes          String?      @db.Text
  occurredAt     DateTime     @map("occurred_at")
  evidenceUrls   String[]     @default([]) @map("evidence_urls")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  @@index([bookingId])
  @@index([nannyProfileId])
  @@index([occurredAt])
  @@map("care_logs")
}

// ──────────────────────────────────────────────────────────────
// Community
// ──────────────────────────────────────────────────────────────

enum CommunityPostType {
  QA
  MARKETPLACE
  EVENT

  @@map("community_post_type")
}

model CommunityPost {
  id            Int               @id @default(autoincrement())
  authorId      Int               @map("author_id")
  author        User              @relation(fields: [authorId], references: [id])
  type          CommunityPostType
  title         String?
  body          String?           @db.Text
  imageUrls     String[]          @default([]) @map("image_urls")
  price         Decimal?          @db.Decimal(10, 2)
  location      String?
  eventStartsAt DateTime?         @map("event_starts_at")
  maxAttendees  Int?              @map("max_attendees")
  rsvpCount     Int               @default(0) @map("rsvp_count")
  tags          String[]          @default([])
  likeCount     Int               @default(0) @map("like_count")
  commentCount  Int               @default(0) @map("comment_count")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  deletedAt     DateTime?         @map("deleted_at")

  likes         PostLike[]
  comments      Comment[]
  rsvps         EventRsvp[]
  conversations Conversation[]

  @@index([type, createdAt])
  @@index([authorId, createdAt])
  @@map("community_posts")
}

model PostLike {
  id        Int           @id @default(autoincrement())
  postId    Int           @map("post_id")
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    Int           @map("user_id")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  deletedAt DateTime?     @map("deleted_at")

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("post_likes")
}

model Comment {
  id              Int           @id @default(autoincrement())
  postId          Int           @map("post_id")
  post            CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId        Int           @map("author_id")
  author          User          @relation(fields: [authorId], references: [id])
  parentCommentId Int?          @map("parent_comment_id")
  parentComment   Comment?      @relation("CommentReplies", fields: [parentCommentId], references: [id])
  replies         Comment[]     @relation("CommentReplies")
  body            String        @db.Text
  likeCount       Int           @default(0) @map("like_count")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")

  likes CommentLike[]

  @@index([postId, createdAt])
  @@index([authorId])
  @@index([parentCommentId])
  @@map("comments")
}

model CommentLike {
  id        Int       @id @default(autoincrement())
  commentId Int       @map("comment_id")
  comment   Comment   @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    Int       @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
  @@map("comment_likes")
}

model EventRsvp {
  id        Int           @id @default(autoincrement())
  postId    Int           @map("post_id")
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    Int           @map("user_id")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  deletedAt DateTime?     @map("deleted_at")

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("event_rsvps")
}

// ──────────────────────────────────────────────────────────────
// Messaging
// ──────────────────────────────────────────────────────────────

enum ConversationType {
  MARKETPLACE

  @@map("conversation_type")
}

enum MessageType {
  TEXT

  @@map("message_type")
}

model Conversation {
  id              Int              @id @default(autoincrement())
  type            ConversationType @default(MARKETPLACE)
  communityPostId Int              @map("community_post_id")
  communityPost   CommunityPost    @relation(fields: [communityPostId], references: [id])
  initiatorId     Int              @map("initiator_id")
  initiator       User             @relation("ConversationInitiator", fields: [initiatorId], references: [id])
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")

  participants ConversationParticipant[]
  messages     Message[]

  @@unique([communityPostId, initiatorId])
  @@index([communityPostId])
  @@index([initiatorId])
  @@map("conversations")
}

model ConversationParticipant {
  id             Int          @id @default(autoincrement())
  conversationId Int          @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         Int          @map("user_id")
  user           User         @relation(fields: [userId], references: [id])
  lastReadAt     DateTime?    @map("last_read_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int          @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       Int          @map("sender_id")
  sender         User         @relation(fields: [senderId], references: [id])
  type           MessageType  @default(TEXT)
  content        String       @db.Text
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}

// ──────────────────────────────────────────────────────────────
// Notifications
// ──────────────────────────────────────────────────────────────

enum NotificationType {
  MARKETPLACE_MESSAGE
  BOOKING_REQUESTED
  BOOKING_APPROVED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  NANNY_CHECKIN
  BOOKING_COMPLETED
  CARE_LOG_ENTRY
  NANNY_APPROVED
  NANNY_REJECTED
  POINTS_EARNED
  POINTS_GRANTED
  POINTS_REDEEMED

  @@map("notification_type")
}

enum NotificationReferenceType {
  CONVERSATION
  BOOKING

  @@map("notification_reference_type")
}

enum DevicePlatform {
  IOS
  ANDROID

  @@map("device_platform")
}

model Notification {
  id            Int                        @id @default(autoincrement())
  userId        Int                        @map("user_id")
  user          User                       @relation(fields: [userId], references: [id])
  type          NotificationType
  title         String
  body          String                     @db.Text
  isRead        Boolean                    @default(false) @map("is_read")
  /// Soft polymorphic reference — a booking or conversation id per
  /// referenceType (no FK constraint).
  referenceId   Int?                       @map("reference_id")
  referenceType NotificationReferenceType? @map("reference_type")
  createdAt     DateTime                   @default(now()) @map("created_at")
  updatedAt     DateTime                   @updatedAt @map("updated_at")
  deletedAt     DateTime?                  @map("deleted_at")

  @@index([userId, isRead, createdAt])
  @@index([userId, type])
  @@map("notifications")
}

model DeviceToken {
  id        Int            @id @default(autoincrement())
  userId    Int            @map("user_id")
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String         @unique
  platform  DevicePlatform
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  deletedAt DateTime?      @map("deleted_at")

  @@index([userId])
  @@map("device_tokens")
}

// ──────────────────────────────────────────────────────────────
// Cameras
// ──────────────────────────────────────────────────────────────

/// A physical/streaming camera managed by admins. Optionally assigned to a
/// nanny user (users.role = NANNY); null = unassigned.
model Camera {
  id          Int       @id @default(autoincrement())
  name        String
  streamUrl   String    @map("stream_url")
  nannyUserId Int?      @map("nanny_user_id")
  nannyUser   User?     @relation("NannyCameras", fields: [nannyUserId], references: [id])
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([nannyUserId])
  @@index([deletedAt])
  @@map("cameras")
}
