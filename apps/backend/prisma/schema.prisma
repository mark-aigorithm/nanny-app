// ──────────────────────────────────────────────────────────────
// NannyApp — Prisma Schema
// ──────────────────────────────────────────────────────────────
// Conventions:
//   • Every model must have created_at, updated_at, deleted_at (soft delete)
//   • DB columns use snake_case via @map; Prisma fields use camelCase
//   • Table names are plural snake_case via @@map
//   • Enums are PascalCase in Prisma, snake_case in DB via @@map
//   • PostGIS geography columns are Unsupported — use $queryRaw
//   • Primary keys are sequential integers: Int @id @default(autoincrement()).
//     Foreign-key columns are Int / Int?. Natural/business identifiers
//     (firebase_uid, email, codes, tokens, paymob ids) remain String.
// ──────────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  // The postgis/postgis Docker image pre-installs these four extensions
  // as part of its init scripts. Declare all of them so Prisma's drift
  // detection matches the actual database state on fresh dev environments.
  extensions = [fuzzystrmatch, postgis, postgis_tiger_geocoder, postgis_topology]
}

// ──────────────────────────────────────────────────────────────
// Auth & Identity
// ──────────────────────────────────────────────────────────────

enum Role {
  MOTHER
  NANNY
  ADMIN
  SUPERUSER

  @@map("role")
}

enum BookingStatus {
  PENDING
  APPROVED
  PENDING_CONFIRMATION
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REFUNDED

  @@map("booking_status")
}

/// Nanny's optional, informational response to a booking request. Purely
/// advisory — the admin's approval is authoritative and overrides this. A
/// nanny may ACCEPT or DECLINE; the booking's lifecycle status is unaffected.
enum NannyBookingDecision {
  PENDING
  ACCEPTED
  DECLINED

  @@map("nanny_booking_decision")
}

enum BookingType {
  STANDARD

  @@map("booking_type")
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED

  @@map("payment_status")
}

enum PaymentMethod {
  CARD
  APPLE_PAY
  GOOGLE_PAY
  WALLET

  @@map("payment_method")
}

/// What a Payment is settling: a Booking (default, existing behaviour) or a
/// PackagePurchase. Disambiguates Payment's polymorphic bookingId /
/// packagePurchaseId relations.
enum PaymentPurpose {
  BOOKING
  PACKAGE
  /// Extra hours added to an already-running booking. See BookingExtension.
  BOOKING_EXTENSION

  @@map("payment_purpose")
}

/// Lifecycle of a mother's mid-shift request for extra hours.
/// PENDING_NANNY → ACCEPTED → PAID is the happy path; the nanny may DECLINE,
/// either side may let it EXPIRE, and ending the booking CANCELs it.
enum BookingExtensionStatus {
  PENDING_NANNY
  ACCEPTED
  PAID
  DECLINED
  EXPIRED
  CANCELLED

  @@map("booking_extension_status")
}

enum NannyApprovalStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED

  @@map("nanny_approval_status")
}

/// Identity-verification state shared by nannies AND mothers (lives on `users`).
/// PENDING_ID = must (re)upload; PENDING_REVIEW = awaiting admin; APPROVED / REJECTED.
enum IdVerificationStatus {
  PENDING_ID
  PENDING_REVIEW
  APPROVED
  REJECTED

  @@map("id_verification_status")
}

/// Government ID kind. PASSPORT needs only the front image; NATIONAL_ID needs both.
enum IdDocumentType {
  PASSPORT
  NATIONAL_ID

  @@map("id_document_type")
}

enum AvailabilityType {
  FULL_TIME
  PART_TIME
  OCCASIONAL

  @@map("availability_type")
}

enum CareLogType {
  MEAL
  NAP
  DIAPER
  ACTIVITY
  CUSTOM

  @@map("care_log_type")
}

/// Central identity row — one per Firebase Auth user.
/// Role-specific data (children, certifications, bio, location) lives on
/// future MotherProfile / NannyProfile models, not here.
/// Note: the spec's single `isVerified` flag is intentionally split into
/// `isEmailVerified` / `isPhoneVerified` — email can be re-verified on
/// change independently of phone (AUTH-10).
model User {
  id                   Int                   @id @default(autoincrement())
  firebaseUid          String                @unique @map("firebase_uid")
  email                String                @unique
  phone                String?               @unique // E.164
  firstName            String                @map("first_name")
  lastName             String                @map("last_name")
  dateOfBirth          DateTime?             @map("date_of_birth") @db.Date
  avatarUrl            String?               @map("avatar_url")
  // Nullable: social sign-in creates a User before the role is chosen;
  // `/auth/set-role` (AUTH-08) fills it in.
  role                 Role?
  isEmailVerified      Boolean               @default(false) @map("is_email_verified")
  isPhoneVerified      Boolean               @default(false) @map("is_phone_verified")
  isActive             Boolean               @default(true) @map("is_active")
  lastLoginAt          DateTime?             @map("last_login_at")
  emailVerifiedAt      DateTime?             @map("email_verified_at")
  phoneVerifiedAt      DateTime?             @map("phone_verified_at")
  termsAcceptedAt      DateTime?             @map("terms_accepted_at")
  termsAcceptedVersion String?               @map("terms_accepted_version")
  /// Street address + home coordinates captured by the registration map
  /// picker. Single source of truth for location — proximity search and
  /// distance sorting (nanny listing + booking broadcast) read lat/lng here.
  address              String?
  latitude             Decimal?              @db.Decimal(10, 7)
  longitude            Decimal?              @db.Decimal(10, 7)
  /// Identity documents + KYC state, for BOTH nannies and mothers. Nannies must
  /// be APPROVED to appear in search / use the app; mothers must have uploaded
  /// an ID (not PENDING_ID/REJECTED) before booking. Null for admins/role-less.
  idVerificationStatus IdVerificationStatus? @map("id_verification_status")
  idDocumentType       IdDocumentType?       @map("id_document_type")
  idDocumentFrontUrl   String?               @map("id_document_front_url")
  idDocumentBackUrl    String?               @map("id_document_back_url")
  idReviewedAt         DateTime?             @map("id_reviewed_at")
  idRejectionReason    String?               @map("id_rejection_reason")
  /// This user's personal referral code (e.g. SARAH-4K2P). Generated lazily on
  /// first request rather than at signup, so existing users need no backfill.
  referralCode         String?               @unique @map("referral_code")
  // Soft-delete grace window (AUTH-14): 30-day window before PII is purged.
  deletionRequestedAt  DateTime?             @map("deletion_requested_at")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  deletedAt            DateTime?             @map("deleted_at")

  nannyProfile             NannyProfile?
  children                 Child[]                   @relation("UserChildren")
  bookingsAsMother         Booking[]                 @relation("BookingMother")
  cancelledBookings        Booking[]                 @relation("BookingCancelledBy")
  approvedBookings         Booking[]                 @relation("BookingAdminApprover")
  actionedBookings         Booking[]                 @relation("BookingAdminActor")
  payments                 Payment[]                 @relation("PaymentMother")
  reviewsGiven             Review[]                  @relation("ReviewMother")
  communityPosts           CommunityPost[]
  postLikes                PostLike[]
  comments                 Comment[]
  commentLikes             CommentLike[]
  eventRsvps               EventRsvp[]
  conversationParticipants ConversationParticipant[]
  messagesSent             Message[]
  notifications            Notification[]
  deviceTokens             DeviceToken[]
  initiatedConversations   Conversation[]            @relation("ConversationInitiator")
  promoRedemptions         PromoCodeRedemption[]
  cameras                  Camera[]                  @relation("NannyCameras")
  rewardWallet             RewardWallet?
  rewardLedger             RewardLedgerEntry[]       @relation("RewardLedgerUser")
  rewardGrantsMade         RewardLedgerEntry[]       @relation("RewardGrantAdmin")
  referralsMade            Referral[]                @relation("ReferralsMade")
  referralReceived         Referral?                 @relation("ReferralReceived")
  packagePurchases         PackagePurchase[]         @relation("PackagePurchaseUser")
  packageHoursLedger       PackageHoursLedger[]      @relation("PackageHoursLedgerUser")
  packageHoursGrants       PackageHoursLedger[]      @relation("PackageHoursLedgerAdmin")
  bookingExtensions        BookingExtension[]        @relation("BookingExtensionMother")

  @@index([role])
  @@index([deletedAt])
  @@index([idVerificationStatus])
  @@map("users")
}

/// Nanny-specific extended profile. Created automatically when role = NANNY
/// on /auth/register. One-to-one with User.
model NannyProfile {
  id                  Int                  @id @default(autoincrement())
  userId              Int                  @unique @map("user_id")
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio                 String?              @db.Text
  yearsOfExperience   Int?                 @map("years_of_experience")
  ageRanges           String[]             @map("age_ranges")
  specialties         String[]             @default([])
  /// Weekly schedule JSON: { "0": { available, startTime, endTime }, … "6": … }
  schedule            Json?
  isProfileComplete   Boolean              @default(false) @map("is_profile_complete")
  /// Admin vetting gate: new nannies start PENDING_REVIEW and cannot appear
  /// in search or use the app until an admin approves them (KYC).
  approvalStatus      NannyApprovalStatus  @default(PENDING_REVIEW) @map("approval_status")
  reviewedAt          DateTime?            @map("reviewed_at")
  rejectionReason     String?              @map("rejection_reason")
  /// Identity documents captured at registration for admin KYC review.
  idDocumentFrontUrl  String?              @map("id_document_front_url")
  idDocumentBackUrl   String?              @map("id_document_back_url")
  /// Availability type for filtering: FULL_TIME, PART_TIME, OCCASIONAL
  availabilityType    AvailabilityType     @default(OCCASIONAL) @map("availability_type")
  /// Denormalised rating cache — recomputed on every new review.
  rating              Decimal              @default(0) @db.Decimal(3, 2)
  reviewCount         Int                  @default(0) @map("review_count")
  bookings            Booking[]
  reviews             Review[]
  careLogs            CareLog[]
  nannySkills         NannySkill[]
  nannyCertifications NannyCertification[]
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  deletedAt           DateTime?            @map("deleted_at")

  @@index([availabilityType])
  @@index([rating])
  @@index([approvalStatus])
  @@map("nanny_profiles")
}

/// Admin-curated catalog of nanny specialties (e.g. "French speaker",
/// "Works with disabilities"). Controlled replacement for the free-text
/// NannyProfile.specialties array. Linked to nannies via NannySkill.
/// A child in a mother's family. Saved once and used to prefill every later
/// booking; a booking then stores its own id-less snapshot (Booking.bookedChildren)
/// so editing or removing a child here never rewrites a past booking's record.
/// The count is what drives the extra-child fee — see resolveExtraChildFee.
model Child {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  user      User      @relation("UserChildren", fields: [userId], references: [id])
  /// Optional — a mother may give ages only, which is all pricing needs.
  name      String?
  /// Whole years. 0 means under one year old.
  ageYears  Int       @map("age_years")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([userId, deletedAt])
  @@map("children")
}

model Skill {
  id          Int           @id @default(autoincrement())
  name        String        @unique
  description String?       @db.Text
  isActive    Boolean       @default(true) @map("is_active")
  /// Optional booking add-on fee. When a mother selects this skill as a paid
  /// add-on, its fee is applied on top of the base hourly rate. null feeType
  /// (the default) means the skill carries no fee. FLAT = EGP/hour surcharge;
  /// PERCENTAGE = percent of the base rate added per hour.
  feeType     DiscountType? @map("fee_type")
  feeValue    Decimal       @default(0) @map("fee_value") @db.Decimal(10, 2)
  nannySkills NannySkill[]
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  @@index([deletedAt])
  @@map("skills")
}

/// Many-to-many join between a nanny and a skill. Assigned by admins.
model NannySkill {
  id             Int          @id @default(autoincrement())
  nannyProfileId Int          @map("nanny_profile_id")
  nannyProfile   NannyProfile @relation(fields: [nannyProfileId], references: [id], onDelete: Cascade)
  skillId        Int          @map("skill_id")
  skill          Skill        @relation(fields: [skillId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  @@unique([nannyProfileId, skillId])
  @@index([nannyProfileId])
  @@index([skillId])
  @@map("nanny_skills")
}

/// Admin-curated catalog of nanny certifications (e.g. "CPR", "First Aid").
/// Controlled replacement for the free-text NannyProfile.certifications array.
/// Linked to nannies via NannyCertification. Unlike Skill, a certification
/// carries no fee — it never affects booking price.
model Certification {
  id                  Int                  @id @default(autoincrement())
  name                String               @unique
  description         String?              @db.Text
  isActive            Boolean              @default(true) @map("is_active")
  nannyCertifications NannyCertification[]
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  deletedAt           DateTime?            @map("deleted_at")

  @@index([deletedAt])
  @@map("certifications")
}

/// Many-to-many join between a nanny and a certification. Selected by the
/// nanny herself from the active catalog (self-service).
model NannyCertification {
  id              Int           @id @default(autoincrement())
  nannyProfileId  Int           @map("nanny_profile_id")
  nannyProfile    NannyProfile  @relation(fields: [nannyProfileId], references: [id], onDelete: Cascade)
  certificationId Int           @map("certification_id")
  certification   Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")

  @@unique([nannyProfileId, certificationId])
  @@index([nannyProfileId])
  @@index([certificationId])
  @@map("nanny_certifications")
}

/// Admin-curated catalog of purchasable hour bundles (e.g. "Starter Pack" —
/// 50 hours for 2000 EGP). Prices are in EGP. Admin-only for now; not yet
/// linked to bookings or parents. `expiresAt` is the catalog offer end date
/// (null = never expires).
model Package {
  id           Int       @id @default(autoincrement())
  name         String    @unique
  description  String?   @db.Text
  hours        Int
  price        Decimal   @db.Decimal(10, 2)
  validityDays Int       @map("validity_days")
  maxSkills    Int       @default(0) @map("max_skills")
  isActive     Boolean   @default(true) @map("is_active")
  expiresAt    DateTime? @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  purchases PackagePurchase[]

  @@index([deletedAt])
  @@map("packages")
}

/// A single purchase of a Package by a user — the hours "bucket" that gets
/// drawn down by bookings via PackageHoursLedger. Snapshots the package's
/// name/price/hours/maxSkills at purchase time so later catalog edits never
/// rewrite the history of a past purchase.
model PackagePurchase {
  id                Int                   @id @default(autoincrement())
  userId            Int                   @map("user_id")
  user              User                  @relation("PackagePurchaseUser", fields: [userId], references: [id])
  packageId         Int                   @map("package_id")
  package           Package               @relation(fields: [packageId], references: [id])
  nameSnapshot      String                @map("name_snapshot")
  hoursPurchased    Int                   @map("hours_purchased")
  pricePaid         Decimal               @map("price_paid") @db.Decimal(10, 2)
  maxSkillsSnapshot Int                   @map("max_skills_snapshot")
  hoursRemaining    Decimal               @default(0) @map("hours_remaining") @db.Decimal(6, 2)
  status            PackagePurchaseStatus @default(PENDING_PAYMENT)
  /// True exactly while `status` is ACTIVE, null otherwise. Paired with
  /// @@unique([userId, isActiveSlot]) this is what actually enforces "at most one
  /// active package per user": Postgres treats NULLs as distinct, so any number of
  /// non-active rows coexist for a user while a second ACTIVE row collides.
  /// The service guard is the friendly pre-check; this is the guarantee.
  isActiveSlot      Boolean?              @map("is_active_slot")
  purchasedAt       DateTime?             @map("purchased_at")
  expiresAt         DateTime?             @map("expires_at")
  /// One purchase accrues MANY payment attempts: a declined card leaves a FAILED
  /// row behind and the retry creates a fresh one, so the history is preserved
  /// rather than overwritten.
  payments          Payment[]
  ledgerEntries     PackageHoursLedger[]
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")
  deletedAt         DateTime?             @map("deleted_at")

  @@unique([userId, isActiveSlot])
  @@index([userId, status])
  @@index([expiresAt])
  @@index([deletedAt])
  @@map("package_purchases")
}

/// Append-only history of every hour movement against a PackagePurchase
/// bucket (purchase credit, booking redemption, refund, expiry, admin
/// adjustment) — mirrors RewardLedgerEntry's ledger pattern for Care Points.
model PackageHoursLedger {
  id           Int                   @id @default(autoincrement())
  purchaseId   Int                   @map("purchase_id")
  purchase     PackagePurchase       @relation(fields: [purchaseId], references: [id])
  userId       Int                   @map("user_id")
  user         User                  @relation("PackageHoursLedgerUser", fields: [userId], references: [id])
  type         PackageHoursEntryType
  hours        Decimal               @db.Decimal(6, 2)
  balanceAfter Decimal               @map("balance_after") @db.Decimal(6, 2)
  reason       String?
  bookingId    Int?                  @map("booking_id")
  booking      Booking?              @relation(fields: [bookingId], references: [id])
  /// Set instead of bookingId when the hours were drawn for a mid-shift
  /// extension. The two are mutually exclusive — see the unique keys below.
  bookingExtensionId Int?            @map("booking_extension_id")
  bookingExtension   BookingExtension? @relation(fields: [bookingExtensionId], references: [id])
  adminId      Int?                  @map("admin_id")
  admin        User?                 @relation("PackageHoursLedgerAdmin", fields: [adminId], references: [id])
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  deletedAt    DateTime?             @map("deleted_at")

  /// One movement of a given type per booking per bucket. This is what actually
  /// enforces refund idempotency: the pre-read guard in refundPackageHours is a
  /// fast path, but two concurrent cancels can both pass it, and the increment
  /// that follows would fabricate hours. Rows with a null bookingId (PURCHASE,
  /// EXPIRY, ADMIN_ADJUST) are unconstrained — Postgres treats NULLs as distinct.
  @@unique([bookingId, purchaseId, type])
  /// The same guarantee for extension-scoped movements. Without it an extension
  /// refund could be applied twice — the key above can't help, because those
  /// rows carry a null bookingId and Postgres treats NULLs as distinct.
  /// Named explicitly: the generated name would exceed Postgres' 63-char
  /// identifier limit and be silently truncated.
  @@unique([bookingExtensionId, purchaseId, type], map: "package_hours_ledger_entries_extension_purchase_type_key")
  @@index([userId, createdAt])
  @@index([purchaseId])
  @@index([bookingId])
  @@index([bookingExtensionId])
  @@map("package_hours_ledger_entries")
}

enum PackagePurchaseStatus {
  PENDING_PAYMENT
  ACTIVE
  EXPIRED
  REFUNDED

  @@map("package_purchase_status")
}

enum PackageHoursEntryType {
  PURCHASE
  REDEMPTION
  REFUND
  EXPIRY
  ADMIN_ADJUST

  @@map("package_hours_entry_type")
}

// ──────────────────────────────────────────────────────────────
// App Config
// ──────────────────────────────────────────────────────────────

/// Singleton key-value store for runtime-configurable settings (e.g. service_fee_percent).
/// Never hard-code config values that operations may need to tune without a deploy.
model AppSettings {
  id        Int       @id @default(autoincrement())
  key       String    @unique
  value     String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("app_settings")
}

enum DiscountType {
  FLAT
  PERCENTAGE

  @@map("discount_type")
}

/// Admin-configured duration pricing tiers. When a booking's durationHours is
/// at least `minHours`, the highest matching tier's `multiplier` is applied to
/// the subtotal (e.g. a 3-hour booking at multiplier 0.90 gets a 10% discount).
/// With no matching tier the multiplier defaults to 1.0 (no adjustment).
model DurationMultiplierRule {
  id         Int       @id @default(autoincrement())
  /// Inclusive lower bound in hours for this tier to apply.
  minHours   Int       @map("min_hours")
  /// Factor applied to the subtotal (0.90 = 10% discount, 1.10 = 10% surcharge).
  multiplier Decimal   @db.Decimal(5, 4)
  label      String?
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@index([isActive])
  @@index([deletedAt])
  @@map("duration_multiplier_rules")
}

model PromoCode {
  id              Int          @id @default(autoincrement())
  code            String       @unique
  discountType    DiscountType @map("discount_type")
  /// Flat amount in EGP, or percentage when discount_type = PERCENTAGE.
  value           Decimal      @db.Decimal(10, 2)
  /// Total redemptions allowed across all users; null = unlimited.
  maxUsage        Int?         @map("max_usage")
  /// Redemptions allowed per user; null = unlimited.
  maxUsagePerUser Int?         @map("max_usage_per_user")
  usageCount      Int          @default(0) @map("usage_count")
  isActive        Boolean      @default(true) @map("is_active")
  expiresAt       DateTime?    @map("expires_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")

  redemptions PromoCodeRedemption[]
  bookings    Booking[]

  @@index([isActive])
  @@index([deletedAt])
  @@map("promo_codes")
}

model PromoCodeRedemption {
  id          Int       @id @default(autoincrement())
  promoCodeId Int       @map("promo_code_id")
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id])
  userId      Int       @map("user_id")
  user        User      @relation(fields: [userId], references: [id])
  /// Soft reference to the booking the code was applied to (no FK constraint).
  bookingId   Int?      @map("booking_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([promoCodeId, userId])
  @@index([userId])
  @@map("promo_code_redemptions")
}

// ──────────────────────────────────────────────────────────────
// Care Points (rewards)
// ──────────────────────────────────────────────────────────────

/// How a Care Points ledger entry moved a balance.
enum RewardEntryType {
  EARN
  REDEEM
  REFUND
  ADMIN_GRANT
  ADMIN_REVOKE
  /// Both sides of a referral payout — the invitee's welcome grant and the
  /// referrer's conversion bonus. The entry's `reason` distinguishes them.
  REFERRAL

  @@map("reward_entry_type")
}

/// Singleton earn/redeem rates for the Care Points program. A single active
/// row is upserted by the admin config screen.
model RewardConfig {
  id                      Int       @id @default(autoincrement())
  enabled                 Boolean   @default(true)
  /// Points granted per completed booked hour.
  pointsPerBookedHour     Int       @default(10) @map("points_per_booked_hour")
  /// Points required to redeem one free care hour.
  redemptionPointsPerHour Int       @default(100) @map("redemption_points_per_hour")
  /// Minimum points a user must spend in a single redemption.
  minRedemptionPoints     Int       @default(100) @map("min_redemption_points")
  /// Master switch for the referral program. When false, codes stop resolving
  /// and pending referrals stop converting (existing payouts are untouched).
  referralEnabled         Boolean   @default(true) @map("referral_enabled")
  /// Points granted to the referrer once their invitee's first booking completes.
  referrerPoints          Int       @default(200) @map("referrer_points")
  /// Points granted to the invitee immediately on redeeming a referral code.
  refereePoints           Int       @default(100) @map("referee_points")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  deletedAt               DateTime? @map("deleted_at")

  @@map("reward_config")
}

/// A user's Care Points balance and redeemed-but-unapplied credit. 1:1 with User.
model RewardWallet {
  id               Int       @id @default(autoincrement())
  userId           Int       @unique @map("user_id")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pointsBalance    Int       @default(0) @map("points_balance")
  lifetimeEarned   Int       @default(0) @map("lifetime_earned")
  lifetimeRedeemed Int       @default(0) @map("lifetime_redeemed")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  entries RewardLedgerEntry[]

  @@map("reward_wallets")
}

/// Append-only history of every Care Points movement (the "wallet history").
model RewardLedgerEntry {
  id           Int             @id @default(autoincrement())
  walletId     Int             @map("wallet_id")
  wallet       RewardWallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)
  userId       Int             @map("user_id")
  user         User            @relation("RewardLedgerUser", fields: [userId], references: [id])
  type         RewardEntryType
  /// Signed delta: positive = credited, negative = debited.
  points       Int
  /// Running balance immediately after this entry was applied.
  balanceAfter Int             @map("balance_after")
  reason       String?
  /// Set on EARN entries (the booking that generated the points).
  bookingId    Int?            @map("booking_id")
  /// Set instead of bookingId when points were spent on a mid-shift extension,
  /// so an extension's REDEEM is distinguishable from the parent booking's own.
  bookingExtensionId Int?      @map("booking_extension_id")
  /// Set on ADMIN_GRANT / ADMIN_REVOKE (the acting admin).
  adminId      Int?            @map("admin_id")
  admin        User?           @relation("RewardGrantAdmin", fields: [adminId], references: [id])
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  deletedAt    DateTime?       @map("deleted_at")

  @@index([userId, createdAt])
  @@index([bookingId])
  @@index([bookingExtensionId])
  @@map("reward_ledger_entries")
}

// ──────────────────────────────────────────────────────────────
// Referrals
// ──────────────────────────────────────────────────────────────

/// Lifecycle of a referral: created when the invitee redeems a code, converted
/// once their first booking completes and the referrer is paid.
enum ReferralStatus {
  PENDING
  CONVERTED

  @@map("referral_status")
}

/// One invitee's referral, from code redemption through payout. The single
/// source of truth for the referrer↔invitee link — deliberately not
/// denormalised onto User, since a plain FK cannot carry pending/converted
/// state and would drift.
model Referral {
  id                  Int            @id @default(autoincrement())
  referrerId          Int            @map("referrer_id")
  referrer            User           @relation("ReferralsMade", fields: [referrerId], references: [id])
  /// Unique: a user can only ever be referred once. This is the feature's core
  /// integrity constraint, enforced by the database rather than by app logic.
  refereeId           Int            @unique @map("referee_id")
  referee             User           @relation("ReferralReceived", fields: [refereeId], references: [id])
  /// The referrer's code as it stood at redemption time.
  code                String
  status              ReferralStatus @default(PENDING)
  /// The invitee's first completed booking, which triggered the payout.
  qualifyingBookingId Int?           @map("qualifying_booking_id")
  /// Point amounts are snapshotted at payout time, so later config changes
  /// never rewrite the history of past referrals.
  referrerPoints      Int            @default(0) @map("referrer_points")
  refereePoints       Int            @default(0) @map("referee_points")
  convertedAt         DateTime?      @map("converted_at")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")
  deletedAt           DateTime?      @map("deleted_at")

  @@index([referrerId, createdAt])
  @@map("referrals")
}

// ──────────────────────────────────────────────────────────────
// Booking & Payments
// ──────────────────────────────────────────────────────────────

model Booking {
  id                       Int                  @id @default(autoincrement())
  motherId                 Int                  @map("mother_id")
  mother                   User                 @relation("BookingMother", fields: [motherId], references: [id])
  /// Null while a broadcast request is unclaimed, until a nanny accepts.
  nannyProfileId           Int?                 @map("nanny_profile_id")
  nannyProfile             NannyProfile?        @relation(fields: [nannyProfileId], references: [id])
  promoCodeId              Int?                 @map("promo_code_id")
  promoCode                PromoCode?           @relation(fields: [promoCodeId], references: [id])
  status                   BookingStatus        @default(PENDING)
  /// Nanny's optional accept/decline of the request. Informational only —
  /// see NannyBookingDecision. Admin approval is authoritative regardless.
  nannyDecision            NannyBookingDecision @default(PENDING) @map("nanny_decision")
  nannyDecidedAt           DateTime?            @map("nanny_decided_at")
  /// Admin who approved the booking (PENDING → APPROVED), plus timestamp.
  adminApprovedById        Int?                 @map("admin_approved_by_id")
  adminApprovedBy          User?                @relation("BookingAdminApprover", fields: [adminApprovedById], references: [id])
  adminApprovedAt          DateTime?            @map("admin_approved_at")
  /// Audit trail for any admin status override (PATCH /admin/bookings/:id/status).
  adminActionById          Int?                 @map("admin_action_by_id")
  adminActionBy            User?                @relation("BookingAdminActor", fields: [adminActionById], references: [id])
  adminActionAt            DateTime?            @map("admin_action_at")
  type                     BookingType          @default(STANDARD)
  date                     DateTime             @db.Date
  startTime                DateTime             @map("start_time")
  endTime                  DateTime             @map("end_time")
  durationHours            Decimal              @map("duration_hours") @db.Decimal(5, 2)
  baseRate                 Decimal              @map("base_rate") @db.Decimal(10, 2)
  /// Base rate plus any selected per-skill add-on fees (per hour).
  effectiveHourlyRate      Decimal              @default(0) @map("effective_hourly_rate") @db.Decimal(10, 2)
  subtotal                 Decimal              @db.Decimal(10, 2)
  /// Duration tier factor applied to the subtotal (1 = none). See DurationMultiplierRule.
  durationMultiplier       Decimal              @default(1) @map("duration_multiplier") @db.Decimal(5, 4)
  discountAmount           Decimal              @default(0) @map("discount_amount") @db.Decimal(10, 2)
  /// Care Points redeemed against this booking before payment: free hours
  /// applied, the points they cost, and their monetary value (folded into
  /// discountAmount). Refunded if the payment is not completed. See RewardWallet.
  rewardCreditHoursApplied Decimal              @default(0) @map("reward_credit_hours_applied") @db.Decimal(6, 2)
  rewardCreditPoints       Int                  @default(0) @map("reward_credit_points")
  rewardCreditAmount       Decimal              @default(0) @map("reward_credit_amount") @db.Decimal(10, 2)
  /// Package hours ("bucket") redeemed against this booking before payment,
  /// the skill add-ons those hours covered, and their monetary value (folded
  /// into discountAmount). See PackagePurchase / PackageHoursLedger.
  packageHoursApplied      Decimal              @default(0) @map("package_hours_applied") @db.Decimal(6, 2)
  packageSkillsCovered     Int                  @default(0) @map("package_skills_covered")
  packageCreditAmount      Decimal              @default(0) @map("package_credit_amount") @db.Decimal(10, 2)
  /// Legacy platform service-fee snapshot. Superseded by the nanny/platform
  /// revenue split (nannyAmount / platformAmount); retained for old bookings.
  serviceFeePercent        Decimal              @map("service_fee_percent") @db.Decimal(5, 2)
  serviceFeeAmount         Decimal              @map("service_fee_amount") @db.Decimal(10, 2)
  totalAmount              Decimal              @map("total_amount") @db.Decimal(10, 2)
  /// Revenue split snapshot: what the nanny earns and what the platform keeps
  /// of totalAmount. Nannies only ever see nannyAmount.
  nannyAmount              Decimal              @default(0) @map("nanny_amount") @db.Decimal(10, 2)
  platformAmount           Decimal              @default(0) @map("platform_amount") @db.Decimal(10, 2)
  /// Snapshot of the selected skill add-ons for the price breakdown display.
  selectedSkillFees        Json?                @map("selected_skill_fees")
  /// How many children this booking covers, how many of those were billed above
  /// the included allowance, and what they added to the hourly rate. The fee is
  /// already inside effectiveHourlyRate — these are kept so the breakdown can be
  /// itemised without re-deriving it from a config that may since have changed.
  /// Defaults describe every booking made before children were modelled.
  childrenCount            Int                  @default(1) @map("children_count")
  extraChildren            Int                  @default(0) @map("extra_children")
  extraChildFeePerHour     Decimal              @default(0) @map("extra_child_fee_per_hour") @db.Decimal(10, 2)
  /// Snapshot of who the booking was for (name + age), like selectedSkillFees.
  bookedChildren           Json?                @map("booked_children")
  specialInstructions      String?              @map("special_instructions") @db.Text
  /// Location snapshot copied from the mother's profile at creation time —
  /// used to radius-filter the nanny broadcast (see notifyBookingBroadcast).
  /// Null (mother has no saved location) → the request broadcasts to everyone.
  latitude                 Decimal?             @db.Decimal(10, 7)
  longitude                Decimal?             @db.Decimal(10, 7)
  cancellationReason       String?              @map("cancellation_reason")
  cancelledById            Int?                 @map("cancelled_by_id")
  cancelledBy              User?                @relation("BookingCancelledBy", fields: [cancelledById], references: [id])
  cancelledAt              DateTime?            @map("cancelled_at")
  nannyCheckedInAt         DateTime?            @map("nanny_checked_in_at")
  nannyCheckedOutAt        DateTime?            @map("nanny_checked_out_at")
  /// When the MOTHER ended the shift early from her app. Deliberately distinct
  /// from nannyCheckedOutAt — that field means the nanny checked herself out,
  /// and writing it here would misreport who closed the shift. A booking
  /// completed this way has motherEndedAt set and nannyCheckedOutAt null.
  motherEndedAt            DateTime?            @map("mother_ended_at")
  /// Parent-generated hand-off PIN gating nanny check-in. The parent reveals a
  /// 4-digit code within the check-in window; the nanny must enter it to start.
  /// Stored hashed (sha-256) and cleared on successful check-in. See booking.service.
  startPinHash             String?              @map("start_pin_hash")
  startPinGeneratedAt      DateTime?            @map("start_pin_generated_at")
  startPinExpiresAt        DateTime?            @map("start_pin_expires_at")
  startPinAttempts         Int                  @default(0) @map("start_pin_attempts")
  /// Last time the parent asked the nanny to turn the camera on. Used purely
  /// as a cooldown so the nanny can't be spammed mid-shift.
  cameraNotifiedAt         DateTime?            @map("camera_notified_at")
  replacementForBookingId  Int?                 @map("replacement_for_booking_id")
  replacementForBooking    Booking?             @relation("BookingReplacement", fields: [replacementForBookingId], references: [id])
  replacementBookings      Booking[]            @relation("BookingReplacement")
  /// One booking accrues MANY payment attempts — see Payment.bookingId.
  payments                 Payment[]
  createdAt                DateTime             @default(now()) @map("created_at")
  updatedAt                DateTime             @updatedAt @map("updated_at")
  deletedAt                DateTime?            @map("deleted_at")

  review             Review?
  careLogs           CareLog[]
  packageHoursLedger PackageHoursLedger[]
  extensions         BookingExtension[]

  @@index([motherId])
  @@index([nannyProfileId])
  @@index([status])
  @@index([nannyDecision])
  @@index([date])
  @@index([promoCodeId])
  @@map("bookings")
}

/// A mother's mid-shift request to add hours to a running booking.
///
/// Money and hours are only ever moved when the row reaches PAID: the request
/// itself is a quote (no credits debited), credits are reserved when the nanny
/// ACCEPTS, and they are returned if the row ends DECLINED / EXPIRED /
/// CANCELLED. Every price field is a SNAPSHOT taken at request time so a later
/// change to platform rates can't retroactively re-price what she agreed to.
model BookingExtension {
  id                       Int                    @id @default(autoincrement())
  bookingId                Int                    @map("booking_id")
  booking                  Booking                @relation(fields: [bookingId], references: [id])
  motherId                 Int                    @map("mother_id")
  mother                   User                   @relation("BookingExtensionMother", fields: [motherId], references: [id])
  status                   BookingExtensionStatus @default(PENDING_NANNY)
  /// Extra hours requested (a preset: 1, 2 or 3).
  hours                    Decimal                @db.Decimal(4, 2)
  /// The booking's endTime if this extension is paid for. Validated against the
  /// platform daily booking window and max duration at request AND accept time.
  newEndTime               DateTime               @map("new_end_time")
  /// Copied from the booking's effectiveHourlyRate — base rate plus the skill
  /// add-ons she already selected. Extensions never re-price the add-ons.
  hourlyRate               Decimal                @map("hourly_rate") @db.Decimal(10, 2)
  subtotal                 Decimal                @db.Decimal(10, 2)
  discountAmount           Decimal                @default(0) @map("discount_amount") @db.Decimal(10, 2)
  /// Package hours reserved against this extension. Returned unless it is PAID.
  packageHoursApplied      Decimal                @default(0) @map("package_hours_applied") @db.Decimal(6, 2)
  packageSkillsCovered     Int                    @default(0) @map("package_skills_covered")
  packageCreditAmount      Decimal                @default(0) @map("package_credit_amount") @db.Decimal(10, 2)
  /// Care Points reserved against this extension. Returned unless it is PAID.
  rewardCreditHoursApplied Decimal                @default(0) @map("reward_credit_hours_applied") @db.Decimal(6, 2)
  rewardCreditPoints       Int                    @default(0) @map("reward_credit_points")
  rewardCreditAmount       Decimal                @default(0) @map("reward_credit_amount") @db.Decimal(10, 2)
  /// What the mother still owes after credits. Zero means it settles with no
  /// trip to Paymob at all.
  totalAmount              Decimal                @map("total_amount") @db.Decimal(10, 2)
  nannyAmount              Decimal                @default(0) @map("nanny_amount") @db.Decimal(10, 2)
  platformAmount           Decimal                @default(0) @map("platform_amount") @db.Decimal(10, 2)
  requestedAt              DateTime               @default(now()) @map("requested_at")
  nannyRespondedAt         DateTime?              @map("nanny_responded_at")
  /// Deadline for the CURRENT status: the nanny's answer while PENDING_NANNY,
  /// then the mother's payment once ACCEPTED. Swept by the reconciliation tick.
  expiresAt                DateTime               @map("expires_at")
  paidAt                   DateTime?              @map("paid_at")
  createdAt                DateTime               @default(now()) @map("created_at")
  updatedAt                DateTime               @updatedAt @map("updated_at")
  deletedAt                DateTime?              @map("deleted_at")

  /// Like Booking, one extension accrues one payment row per attempt.
  payments           Payment[]
  packageHoursLedger PackageHoursLedger[]

  @@index([bookingId])
  @@index([motherId])
  @@index([status, expiresAt])
  @@map("booking_extensions")
}

model Payment {
  id                      Int              @id @default(autoincrement())
  /// Nullable + polymorphic: a payment covers either a Booking, a
  /// PackagePurchase or a BookingExtension (never more than one). `purpose`
  /// disambiguates which relation is populated.
  /// Neither FK is unique: every payment ATTEMPT gets its own row, so a declined
  /// card keeps its FAILED record and the retry is a new one rather than an
  /// overwrite. Consumers that want "the" payment take the newest.
  bookingId               Int?             @map("booking_id")
  booking                 Booking?         @relation(fields: [bookingId], references: [id])
  packagePurchaseId       Int?             @map("package_purchase_id")
  packagePurchase         PackagePurchase? @relation(fields: [packagePurchaseId], references: [id])
  bookingExtensionId      Int?              @map("booking_extension_id")
  bookingExtension        BookingExtension? @relation(fields: [bookingExtensionId], references: [id])
  purpose                 PaymentPurpose   @default(BOOKING)
  motherId                Int              @map("mother_id")
  mother                  User             @relation("PaymentMother", fields: [motherId], references: [id])
  amount                  Decimal          @db.Decimal(10, 2)
  currency                String           @default("EGP")
  method                  PaymentMethod
  status                  PaymentStatus    @default(PENDING)
  paymobOrderId           String?          @map("paymob_order_id")
  paymobTransactionId     String?          @map("paymob_transaction_id")
  /// Paymob unified intention id (`id` from create-intention response).
  paymobIntentionId       String?          @map("paymob_intention_id")
  /// One-time client secret for Pixel / unified checkout and for server-side intention polling.
  paymobClientSecret      String?          @map("paymob_client_secret") @db.Text
  /// Incremented each time a new Paymob intention is created (retry-safe merchant order ids).
  paymobIntentionAttempt  Int              @default(0) @map("paymob_intention_attempt")
  /// T0 for staggered reconciliation (usually intention creation time).
  paymobReconcileAnchorAt DateTime?        @map("paymob_reconcile_anchor_at")
  /// Number of reconciliation polls already executed (0..PAYMOB_RECONCILE_OFFSETS_MS.length).
  paymobReconcileAttempt  Int              @default(0) @map("paymob_reconcile_attempt")
  paymobNextReconcileAt   DateTime?        @map("paymob_next_reconcile_at")
  failureReason           String?          @map("failure_reason")
  refundedAmount          Decimal          @default(0) @map("refunded_amount") @db.Decimal(10, 2)
  refundedAt              DateTime?        @map("refunded_at")
  createdAt               DateTime         @default(now()) @map("created_at")
  updatedAt               DateTime         @updatedAt @map("updated_at")
  deletedAt               DateTime?        @map("deleted_at")

  @@index([paymobOrderId])
  @@index([paymobNextReconcileAt])
  /// Replace the indexes the dropped @unique constraints used to provide — both
  /// flows look payments up by owner to find the latest attempt. Extensions
  /// resolve their newest attempt the same way.
  @@index([bookingExtensionId])
  @@index([packagePurchaseId])
  @@index([bookingId])
  @@map("payments")
}

// ──────────────────────────────────────────────────────────────
// Reviews
// ──────────────────────────────────────────────────────────────

model Review {
  id             Int          @id @default(autoincrement())
  bookingId      Int          @unique @map("booking_id")
  booking        Booking      @relation(fields: [bookingId], references: [id])
  nannyProfileId Int          @map("nanny_profile_id")
  nannyProfile   NannyProfile @relation(fields: [nannyProfileId], references: [id])
  motherId       Int          @map("mother_id")
  mother         User         @relation("ReviewMother", fields: [motherId], references: [id])
  rating         Int
  comment        String?      @db.Text
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  @@index([nannyProfileId])
  @@index([motherId])
  @@map("reviews")
}

// ──────────────────────────────────────────────────────────────
// Care Logs
// ──────────────────────────────────────────────────────────────

/// One entry per logged activity during an in-progress booking.
/// `customLabel` is required only for type = CUSTOM. Evidence is a list of
/// remote image URLs (clients upload the file to Firebase Storage first and
/// then submit the resulting URL).
model CareLog {
  id             Int          @id @default(autoincrement())
  bookingId      Int          @map("booking_id")
  booking        Booking      @relation(fields: [bookingId], references: [id])
  nannyProfileId Int          @map("nanny_profile_id")
  nannyProfile   NannyProfile @relation(fields: [nannyProfileId], references: [id])
  type           CareLogType
  customLabel    String?      @map("custom_label")
  notes          String?      @db.Text
  occurredAt     DateTime     @map("occurred_at")
  evidenceUrls   String[]     @default([]) @map("evidence_urls")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  @@index([bookingId])
  @@index([nannyProfileId])
  @@index([occurredAt])
  @@map("care_logs")
}

// ──────────────────────────────────────────────────────────────
// Community
// ──────────────────────────────────────────────────────────────

enum CommunityPostType {
  QA
  MARKETPLACE
  EVENT

  @@map("community_post_type")
}

model CommunityPost {
  id            Int               @id @default(autoincrement())
  authorId      Int               @map("author_id")
  author        User              @relation(fields: [authorId], references: [id])
  type          CommunityPostType
  title         String?
  body          String?           @db.Text
  imageUrls     String[]          @default([]) @map("image_urls")
  price         Decimal?          @db.Decimal(10, 2)
  location      String?
  eventStartsAt DateTime?         @map("event_starts_at")
  maxAttendees  Int?              @map("max_attendees")
  rsvpCount     Int               @default(0) @map("rsvp_count")
  tags          String[]          @default([])
  likeCount     Int               @default(0) @map("like_count")
  commentCount  Int               @default(0) @map("comment_count")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  deletedAt     DateTime?         @map("deleted_at")

  likes         PostLike[]
  comments      Comment[]
  rsvps         EventRsvp[]
  conversations Conversation[]

  @@index([type, createdAt])
  @@index([authorId, createdAt])
  @@map("community_posts")
}

model PostLike {
  id        Int           @id @default(autoincrement())
  postId    Int           @map("post_id")
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    Int           @map("user_id")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  deletedAt DateTime?     @map("deleted_at")

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("post_likes")
}

model Comment {
  id              Int           @id @default(autoincrement())
  postId          Int           @map("post_id")
  post            CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId        Int           @map("author_id")
  author          User          @relation(fields: [authorId], references: [id])
  parentCommentId Int?          @map("parent_comment_id")
  parentComment   Comment?      @relation("CommentReplies", fields: [parentCommentId], references: [id])
  replies         Comment[]     @relation("CommentReplies")
  body            String        @db.Text
  likeCount       Int           @default(0) @map("like_count")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")

  likes CommentLike[]

  @@index([postId, createdAt])
  @@index([authorId])
  @@index([parentCommentId])
  @@map("comments")
}

model CommentLike {
  id        Int       @id @default(autoincrement())
  commentId Int       @map("comment_id")
  comment   Comment   @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    Int       @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
  @@map("comment_likes")
}

model EventRsvp {
  id        Int           @id @default(autoincrement())
  postId    Int           @map("post_id")
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    Int           @map("user_id")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  deletedAt DateTime?     @map("deleted_at")

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("event_rsvps")
}

// ──────────────────────────────────────────────────────────────
// Messaging
// ──────────────────────────────────────────────────────────────

enum ConversationType {
  MARKETPLACE

  @@map("conversation_type")
}

enum MessageType {
  TEXT

  @@map("message_type")
}

model Conversation {
  id              Int              @id @default(autoincrement())
  type            ConversationType @default(MARKETPLACE)
  communityPostId Int              @map("community_post_id")
  communityPost   CommunityPost    @relation(fields: [communityPostId], references: [id])
  initiatorId     Int              @map("initiator_id")
  initiator       User             @relation("ConversationInitiator", fields: [initiatorId], references: [id])
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")

  participants ConversationParticipant[]
  messages     Message[]

  @@unique([communityPostId, initiatorId])
  @@index([communityPostId])
  @@index([initiatorId])
  @@map("conversations")
}

model ConversationParticipant {
  id             Int          @id @default(autoincrement())
  conversationId Int          @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         Int          @map("user_id")
  user           User         @relation(fields: [userId], references: [id])
  lastReadAt     DateTime?    @map("last_read_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int          @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       Int          @map("sender_id")
  sender         User         @relation(fields: [senderId], references: [id])
  type           MessageType  @default(TEXT)
  content        String       @db.Text
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}

// ──────────────────────────────────────────────────────────────
// Notifications
// ──────────────────────────────────────────────────────────────

enum NotificationType {
  MARKETPLACE_MESSAGE
  BOOKING_REQUESTED
  BOOKING_APPROVED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  NANNY_CHECKIN
  BOOKING_COMPLETED
  CARE_LOG_ENTRY
  NANNY_APPROVED
  NANNY_REJECTED
  POINTS_EARNED
  POINTS_GRANTED
  POINTS_REDEEMED
  /// An invitee's first booking completed, paying out the referrer.
  REFERRAL_CONVERTED
  /// An invitee redeemed a referral code and received their welcome grant.
  REFERRAL_JOINED
  /// A parent asked the nanny to turn on the camera for a live booking.
  CAMERA_REQUESTED
  /// A parent ended a running booking early from her app.
  BOOKING_ENDED_BY_PARENT
  /// A parent asked to add hours to a running booking (nanny must answer).
  BOOKING_EXTENSION_REQUESTED
  /// The nanny accepted the extra hours — the parent still has to pay.
  BOOKING_EXTENSION_ACCEPTED
  /// The nanny turned the extra hours down.
  BOOKING_EXTENSION_DECLINED
  /// The extension was paid for and the booking's end time has moved.
  BOOKING_EXTENDED

  @@map("notification_type")
}

enum NotificationReferenceType {
  CONVERSATION
  BOOKING

  @@map("notification_reference_type")
}

enum DevicePlatform {
  IOS
  ANDROID

  @@map("device_platform")
}

model Notification {
  id            Int                        @id @default(autoincrement())
  userId        Int                        @map("user_id")
  user          User                       @relation(fields: [userId], references: [id])
  type          NotificationType
  title         String
  body          String                     @db.Text
  isRead        Boolean                    @default(false) @map("is_read")
  /// Soft polymorphic reference — a booking or conversation id per
  /// referenceType (no FK constraint).
  referenceId   Int?                       @map("reference_id")
  referenceType NotificationReferenceType? @map("reference_type")
  createdAt     DateTime                   @default(now()) @map("created_at")
  updatedAt     DateTime                   @updatedAt @map("updated_at")
  deletedAt     DateTime?                  @map("deleted_at")

  @@index([userId, isRead, createdAt])
  @@index([userId, type])
  @@map("notifications")
}

model DeviceToken {
  id        Int            @id @default(autoincrement())
  userId    Int            @map("user_id")
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String         @unique
  platform  DevicePlatform
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  deletedAt DateTime?      @map("deleted_at")

  @@index([userId])
  @@map("device_tokens")
}

// ──────────────────────────────────────────────────────────────
// Cameras
// ──────────────────────────────────────────────────────────────

/// A physical/streaming camera managed by admins. Optionally assigned to a
/// nanny user (users.role = NANNY); null = unassigned.
model Camera {
  id          Int       @id @default(autoincrement())
  name        String
  streamUrl   String    @map("stream_url")
  nannyUserId Int?      @map("nanny_user_id")
  nannyUser   User?     @relation("NannyCameras", fields: [nannyUserId], references: [id])
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([nannyUserId])
  @@index([deletedAt])
  @@map("cameras")
}
